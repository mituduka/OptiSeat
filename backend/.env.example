# OptiSeat バックエンド環境変数サンプル
#
# このファイルをコピーして `.env` を作成し、必要に応じて値を上書きしてください。
#   cp backend/.env.example backend/.env
# すべて任意。未設定時は以下のデフォルト値が使われます（backend/api/config.py 参照）。
#
# docker compose 起動時はこのファイル（backend/.env）が自動で読み込まれます
# （docker-compose.yml / docker-compose.dev.yml の env_file 指定、ファイルが無くても起動可）。
# ポート・CORS はルートの .env で制御してください（compose の environment が優先されるため、
# CORS_ORIGINS をここに書いても上書きされます）。

# --- バリデーション上限 ---
# 1クラスの最大児童数
MAX_STUDENTS=50

# 教室グリッドの最大行数・列数
SEAT_MAX_ROWS=12
SEAT_MAX_COLS=12

# --- ソルバ設定 ---
# デフォルト／上限のタイムアウト秒数
SOLVER_TIMEOUT_DEFAULT=30
SOLVER_TIMEOUT_MAX=120

# 取得する解候補数（デフォルト／上限）
SOLVER_MAX_SOLUTIONS_DEFAULT=5
SOLVER_MAX_SOLUTIONS_MAX=10

# clingo の --rand-freq（0〜1）。1 に近いほど多様な解が得られるが収束が遅くなる
SOLVER_RAND_FREQ=1.0

# ソルバ並列実行のワーカー数。未設定時は CPU コア数
# SOLVER_WORKERS=4
