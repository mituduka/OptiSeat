%=============================================================================
% base.lp — Generate（割り当て生成）と Define（補助述語定義）
%
% Hard 制約は hard.lp、Soft 制約（最適化）は soft.lp で定義する。
%=============================================================================


%-----------------------------------------------------------------------------
% Generate: 各児童・生徒に席をちょうど 1 つ割り当てる
%
% choice rule: 「各児童・生徒 S に対して、存在する座席のうちちょうど 1 つを選ぶ」
% hard.lp の H-02 と組み合わせて「1 人 1 席、1 席 1 人」を保証する。
%-----------------------------------------------------------------------------

1 { assign(S, R) : seat(R, _, _) } 1 :- student(S, _).


%-----------------------------------------------------------------------------
% Define: 8方向隣接関係
%
% adjacent8(R1, R2) は R1 と R2 が上下左右斜め 8 方向で隣接していることを示す対称関係。
% ・幾何条件（seat×seat ＋ 距離判定）は R1 < R2 の対だけで評価し、
%   逆方向は定義の対称性で補うことで計算コストの削減を狙う。
% ・H-04 は assign(S1,R1)・assign(S2,R2) を座席の順序を問わず参照するため、この対称化は必須。
%-----------------------------------------------------------------------------

adjacent8(R1, R2) :-
    seat(R1, Row1, Col1),
    seat(R2, Row2, Col2),
    R1 < R2,
    |Row1 - Row2| <= 1,
    |Col1 - Col2| <= 1.

adjacent8(R2, R1) :- adjacent8(R1, R2).


%-----------------------------------------------------------------------------
% Define: 前列・後列ゾーン
%
% front_row(Row) / back_row(Row) は facts.py が FactBase に追加する入力ファクト。
% ・省略時は Python レイヤーで最終行を自動補完する（back_row のみ）。
% ・現時点では各ゾーン 1 行のみを想定。
%-----------------------------------------------------------------------------

% 座席が前列に属するか
in_front(R) :- seat(R, Row, _), front_row(Row).

% 座席が後列に属するか（back_row は入力ファクトを参照）
in_back(R) :- seat(R, Row, _), back_row(Row).


%-----------------------------------------------------------------------------
% Define: 班（グループ）関連
%
% group(G, R) は「座席 R が班 G に属する」という入力ファクト。
% assign が確定した後に in_group が解釈される点に注意。
%-----------------------------------------------------------------------------

% 児童・生徒 S が班 G に所属しているか（assign 経由で逆引き）
in_group(S, G) :- assign(S, R), group(G, R).

% 班内に男性・女性が存在するか（S-03 の補助述語）
group_has_male(G)   :- in_group(S, G), student(S, male).
group_has_female(G) :- in_group(S, G), student(S, female).

% 班 ID の一覧（ユニーク）
% group(G, _) は同一 G に複数ファクトが存在するため、
% Soft 制約でグループ単位 1 件のペナルティを実現するために使用する。
group_id(G) :- group(G, _).


%-----------------------------------------------------------------------------
% Define: 座席存在チェック（相対的固定制約 H-08 の補助述語）
%-----------------------------------------------------------------------------

has_seat(Row, Col) :- seat(_, Row, Col).
