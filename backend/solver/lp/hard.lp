%=============================================================================
% hard.lp — Hard 制約（必須条件）
%
% ここに記述した integrity constraint（:- ...）に違反する解は
% clingo によって完全に除外され、解として返されない。
%=============================================================================


%-----------------------------------------------------------------------------
% H-01: 1 人 1 席の保証
%
% base.lp の choice rule「1 { assign(S, R) : ... } 1」で
% 各児童・生徒にちょうど 1 席が割り当てられることは保証済み。
% （ここでは明示的な integrity constraint は不要）
%-----------------------------------------------------------------------------


%-----------------------------------------------------------------------------
% H-02: 1 席に複数人を配置してはならない
%
% 同じ座席 R に 2 人以上の児童・生徒が割り当てられた解を除外する。
%-----------------------------------------------------------------------------

:- seat(R, _, _),
   #count { S : assign(S, R) } > 1.


%-----------------------------------------------------------------------------
% H-03: 座席固定
%
% fixed(S, R) が指定されている場合、必ず assign(S, R) でなければならない。
% 違反した解（別の座席に配置された解）は除外される。
%-----------------------------------------------------------------------------

:- fixed(S, R), not assign(S, R).


%-----------------------------------------------------------------------------
% H-04: 8方向隣接禁止ペア（斜め含む）
%
% forbidden8(S1, S2) のペアが 8 方向（斜め含む）で隣接する座席に配置された
% 解を除外する。adjacent8 は base.lp で定義。
%-----------------------------------------------------------------------------

:- forbidden8(S1, S2),
   assign(S1, R1),
   assign(S2, R2),
   adjacent8(R1, R2).


%-----------------------------------------------------------------------------
% H-05: 同班禁止ペア
%
% forbidden_group(S1, S2) のペアが同じ班に配置された解を除外する。
% in_group は base.lp で定義（assign 経由で解釈）。
%-----------------------------------------------------------------------------

:- forbidden_group(S1, S2),
   in_group(S1, G),
   in_group(S2, G).


%-----------------------------------------------------------------------------
% H-06: 座席性別制約
%
% seat_gender_constraint(R, Gender) が指定されている場合、
% その座席 R に対して指定外の性別の児童・生徒が配置された解を除外する。
%-----------------------------------------------------------------------------

:- assign(S, R),
   student(S, StuGender),
   seat_gender_constraint(R, AllowedGender),
   StuGender != AllowedGender.

% 補助: 性別ごとの容量チェック（冗長制約）
%
% 「性別 G の人数 > G が座れる座席数」は鳩の巣原理により必ず解なしだが、
% 上記の割り当てレベルの制約だけでは CDCL ソルバが探索の枚挙でしか
% 証明できず、UNSAT の確定に指数時間かかる（タイムアウトの原因になる）。
% 人数と座席数はグラウンド時に定数として評価されるため、
% このカウント制約により容量超過の UNSAT が即座に確定する。

gender_domain(G) :- student(_, G).

% 座席 R に性別 G 以外の専用指定があるか
seat_gender_excluded(R, G) :-
   seat(R, _, _),
   gender_domain(G),
   seat_gender_constraint(R, AllowedGender),
   G != AllowedGender.

% 座席 R に性別 G を配置できるか（専用指定なし、または G 指定）
seat_allows_gender(R, G) :-
   seat(R, _, _),
   gender_domain(G),
   not seat_gender_excluded(R, G).

:- gender_domain(G),
   N = #count { S : student(S, G) },
   C = #count { R : seat_allows_gender(R, G) },
   N > C.


%-----------------------------------------------------------------------------
% H-08: 相対的固定制約（隣接固定制約）
%
% relative_fixed(SA, SB, DRow, DCol) が指定されている場合:
%   1. SA が配置された座席から (DRow, DCol) 先に座席が存在しなければならない
%   2. その座席に SB が配置されなければならない
%-----------------------------------------------------------------------------

% ルール1: 目標座席が存在しない位置に SA を配置してはならない
:- relative_fixed(SA, SB, DR, DC),
   assign(SA, R1),
   seat(R1, Row1, Col1),
   not has_seat(Row1+DR, Col1+DC).

% ルール2: 目標座席が存在する場合、SB がそこに配置されなければならない
:- relative_fixed(SA, SB, DR, DC),
   assign(SA, R1),
   seat(R1, Row1, Col1),
   seat(R2, Row1+DR, Col1+DC),
   not assign(SB, R2).


%-----------------------------------------------------------------------------
% H-10: 班分散グループメンバーは同じ班に配置されない
%
% leader_group(G, S) が指定されているメンバー同士が同じ班 CG に配置された解を除外。
% in_group は base.lp で定義（assign 経由で解釈）。
%-----------------------------------------------------------------------------

:- leader_group(G, S1),
   leader_group(G, S2),
   S1 < S2,
   in_group(S1, CG),
   in_group(S2, CG).

